#!/usr/bin/env bash

set -o errexit -o nounset -o pipefail

# Parse flags before forwarding remaining args to darcs
stat=0
darcs_args=()
for arg in "$@"; do
    case "$arg" in
        --stat|-s) stat=1 ;;
        --help|-h)
            echo "Usage: darcs-pl [-s] [darcs log options]"
            echo ""
            echo "Options:"
            echo "  -h, --help    Show this help"
            echo "  -s, --stat    Show files changed per patch"
            echo ""
            echo "Any other options are forwarded to darcs log."
            exit 0 ;;
        *) darcs_args+=("$arg") ;;
    esac
done

# Try to detect unpushed patches; timeout avoids hanging on slow/unavailable remotes
has_remote=0
unpushed_hashes=""
if darcs_dry=$(timeout 10 darcs push --dry-run 2>/dev/null); then
    has_remote=1
    unpushed_hashes=$(printf '%s\n' "$darcs_dry" | awk '/^patch / { printf "%s,", substr($2, 1, 8) }')
fi

if [[ $stat -eq 1 ]]; then
    log_flag="--verbose"
else
    log_flag="--no-summary"
fi

darcs log "$log_flag" "${darcs_args[@]+"${darcs_args[@]}"}" | awk \
    -v unpushed="$unpushed_hashes" \
    -v has_remote="$has_remote" \
    -v stat="$stat" '
    BEGIN {
        n = split(unpushed, arr, ",")
        for (i = 1; i <= n; i++)
            if (arr[i] != "") local_set[arr[i]] = 1
        origin_marked = 0
    }
    function relative(epoch,    diff, n, u) {
        diff = systime() - epoch
        if      (diff < 60)       { n=diff;             u=(n==1?"second":"seconds") }
        else if (diff < 3600)     { n=int(diff/60);     u=(n==1?"minute":"minutes") }
        else if (diff < 86400)    { n=int(diff/3600);   u=(n==1?"hour":"hours")     }
        else if (diff < 604800)   { n=int(diff/86400);  u=(n==1?"day":"days")       }
        else if (diff < 2592000)  { n=int(diff/604800); u=(n==1?"week":"weeks")     }
        else if (diff < 31536000) { n=int(diff/2592000);u=(n==1?"month":"months")   }
        else                      { n=int(diff/31536000);u=(n==1?"year":"years")    }
        return "(" n " " u " ago)"
    }
    function isort(arr, n,    i, j, tmp) {
        for (i = 2; i <= n; i++) {
            tmp = arr[i]; j = i - 1
            while (j >= 1 && arr[j] > tmp) { arr[j+1] = arr[j]; j-- }
            arr[j+1] = tmp
        }
    }
    function flush(    i, f, keys, nkeys, op, rest, color) {
        if (pending_line == "") return
        print pending_line
        if (stat) {
            delete keys
            nkeys = 0
            for (f in pending_op) keys[++nkeys] = f
            isort(keys, nkeys)
            for (i = 1; i <= nkeys; i++) {
                f  = keys[i]
                op = substr(pending_op[f], 1, 1)
                if (op == "_") continue
                rest = (op == "R") ? f " -> " substr(pending_op[f], 3) : f
                if      (op == "A") color = "\033[32m"
                else if (op == "D") color = "\033[31m"
                else if (op == "R") color = "\033[33m"
                else                color = "\033[2m"
                print "  " color op "\033[0m \033[2m" rest "\033[0m"
            }
        }
        pending_line = ""
        delete pending_op
    }
    /^patch / {
        flush()
        hash = substr($2, 1, 8)
    }
    /^Author: / {
        sub(/^Author: /, "")
        match($0, /^[^<]+/)
        author = substr($0, 1, RLENGTH)
        gsub(/[ \t]+$/, "", author)
    }
    /^Date: / {
        sub(/^Date:[ \t]+/, "")
        split($0, p, " ")
        split(p[4], t, ":")
        split("Jan Feb Mar Apr May Jun Jul Aug Sep Oct Nov Dec", mn)
        for (i=1; i<=12; i++) if (mn[i] == p[2]) { mon=i; break }
        epoch = mktime(p[6] " " mon " " p[3] " " t[1] " " t[2] " " t[3])
        date = relative(epoch)
    }
    /^  tagged / {
        tagname = substr($0, 10)
        pending = pending == "" ? tagname : pending ", " tagname
    }
    /^  \* / {
        decorations = ""
        if (has_remote && !origin_marked && !(hash in local_set)) {
            decorations = "defaultrepo"
            origin_marked = 1
        }
        if (pending != "") {
            decorations = decorations == "" ? "tag: " pending : decorations ", tag: " pending
            pending = ""
        }
        tag_str = decorations != "" ? " \033[33m(" decorations ")\033[0m" : ""

        msg = substr($0, 5)
        pending_line = sprintf("* \033[31m%s\033[0m -%s %s \033[32m%s\033[0m \033[1;34m<%s>\033[0m", hash, tag_str, msg, date, author)
    }
    stat && /^    hunk / {
        f = $2; sub(/^\.\//, "", f)
        if (!(f in pending_op)) pending_op[f] = "M"
    }
    stat && /^    addfile / {
        f = $2; sub(/^\.\//, "", f)
        if (!(f in pending_op)) pending_op[f] = "A"
    }
    stat && /^    rmfile / {
        f = $2; sub(/^\.\//, "", f)
        if (!(f in pending_op)) pending_op[f] = "D"
    }
    stat && /^    move / {
        src = $2; sub(/^\.\//, "", src)
        dst = $3; sub(/^\.\//, "", dst)
        if (!(src in pending_op)) pending_op[src] = "R " dst
        if (!(dst in pending_op)) pending_op[dst] = "_"
    }
    END { flush() }
' | { [ -t 1 ] && less -R || cat; }
